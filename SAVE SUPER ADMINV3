<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>ScoreTrak SuperAdmin - Professional Monitor</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Roboto:wght@400;700;900&display=swap');
        
        :root { 
            --padel-yellow: #ccff00; 
            --padel-blue: #00d2ff; 
            --bg-dark: #000; 
            --card-bg: #0d0d0d; 
            --border: #222; 
        }
        
        body { background: var(--bg-dark); color: white; font-family: 'Roboto', sans-serif; margin: 0; display: flex; height: 100vh; overflow: hidden; }
        
        /* SIDEBAR */
        #sidebar { width: 260px; background: #050505; border-right: 1px solid var(--border); padding: 25px; display: flex; flex-direction: column; }
        .logo { font-family: 'Orbitron'; color: var(--padel-yellow); font-size: 22px; margin-bottom: 40px; font-style: italic; font-weight: 900; letter-spacing: -1px; }
        .nav-item { padding: 14px; cursor: pointer; border-radius: 10px; margin-bottom: 8px; color: #666; transition: 0.3s; font-weight: bold; }
        .nav-item.active { background: var(--padel-yellow); color: #000; }
        .nav-item:hover:not(.active) { color: #fff; background: #111; }

        #main { flex: 1; padding: 40px; overflow-y: auto; background: radial-gradient(circle at top right, #111, #000); }
        .view { display: none; } .view.active { display: block; }
        h1 { font-family: 'Orbitron'; font-size: 24px; margin-bottom: 30px; text-transform: uppercase; }
        h1 span { color: var(--padel-yellow); }

        /* FILTRES */
        .filter-bar { display: flex; gap: 15px; margin-bottom: 30px; background: rgba(255,255,255,0.03); padding: 15px; border-radius: 15px; border: 1px solid var(--border); }
        .search-input { flex: 1; background: #000; border: 1px solid #333; padding: 12px; border-radius: 8px; color: white; border-left: 4px solid var(--padel-blue); }
        .select-club { background: #000; color: white; border: 1px solid #333; padding: 12px; border-radius: 8px; min-width: 200px; }

        /* MONITOR CARD */
        .monitor-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 20px; }
        .monitor-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 20px; padding: 20px; transition: 0.3s; }
        .monitor-card.live { border-color: var(--padel-yellow); }
        .monitor-card.setup { border-color: var(--padel-blue); }
        .monitor-card.finished { border-color: #ff4444; }

        .card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px; }
        .club-tag { font-size: 10px; color: var(--padel-blue); font-weight: 900; text-transform: uppercase; letter-spacing: 1px; }
        .status-label { font-size: 9px; font-weight: 900; color: #555; text-transform: uppercase; border: 1px solid #333; padding: 2px 6px; border-radius: 4px; }

        /* SCORE DISPLAY */
        .score-container { display: flex; flex-direction: column; gap: 10px; }
        .team-row { display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.02); padding: 10px 15px; border-radius: 12px; height: 50px; }
        .player-info { flex: 1; }
        .player-names { font-size: 13px; font-weight: 900; text-transform: uppercase; color: #fff; }
        .set-history { display: flex; gap: 5px; margin-top: 4px; }
        .set-pill { background: var(--padel-blue); color: #000; font-size: 10px; font-weight: 900; padding: 1px 6px; border-radius: 40px; }
        
        .current-point { font-family: 'Orbitron'; font-size: 24px; color: var(--padel-yellow); width: 50px; text-align: right; }

        /* ACTIONS */
        .btn-reset { background: #1a0000; color: #ff4444; border: 1px solid #300; width: 100%; padding: 10px; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 10px; margin-top: 15px; text-transform: uppercase; }
        .btn-reset:hover { background: #ff4444; color: #000; }

        /* CONFIG */
        .club-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 20px; padding: 25px; margin-bottom: 25px; }
        .court-row { display: flex; justify-content: space-between; align-items: center; background: #111; padding: 12px; border-radius: 10px; margin-bottom: 8px; border: 1px solid #222; }
        .btn-copy { background: var(--padel-blue); color: #000; padding: 8px 15px; font-size: 11px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; }
        .primary-btn { background: var(--padel-yellow); color: #000; border: none; padding: 12px 25px; border-radius: 8px; font-weight: bold; cursor: pointer; }

        /* LOGIN */
        #login-overlay { position: fixed; inset: 0; background: #000; z-index: 2000; display: flex; justify-content: center; align-items: center; }
        .login-box { background: #0a0a0a; padding: 50px; border-radius: 30px; border: 1px solid var(--padel-yellow); text-align: center; width: 350px; }
    </style>
</head>
<body>

    <div id="login-overlay">
        <div class="login-box">
            <div class="logo">ScoreTrak Admin</div>
            <input type="text" id="adm-u" placeholder="Identifiant" style="width:100%; padding:12px; margin-bottom:10px; border-radius:8px; border:1px solid #333; background:#000; color:#fff;">
            <input type="password" id="adm-p" placeholder="Mot de passe" style="width:100%; padding:12px; margin-bottom:20px; border-radius:8px; border:1px solid #333; background:#000; color:#fff;">
            <button onclick="login()" class="primary-btn" style="width:100%">CONNEXION</button>
        </div>
    </div>

    <div id="sidebar">
        <div class="logo">ScoreTrak</div>
        <div class="nav-item active" id="nav-dash" onclick="showView('dash')">📊 MONITORING LIVE</div>
        <div class="nav-item" id="nav-conf" onclick="showView('conf')">⚙️ CONFIG CLUBS</div>
        <div style="margin-top:auto; font-size:10px; color:#333;">V5.0 - PRO EDITION</div>
    </div>

    <div id="main">
        <div id="view-dash" class="view active">
            <h1>Surveillance <span>Temps Réel</span></h1>
            
            <div class="filter-bar">
                <select id="filter-club" class="select-club" onchange="renderDashboard()">
                    <option value="all">TOUS LES CLUBS</option>
                </select>
                <input type="text" id="search-court" class="search-input" placeholder="Rechercher une piste par nom..." onkeyup="renderDashboard()">
            </div>

            <div class="monitor-grid" id="monitor-list"></div>
        </div>

        <div id="view-conf" class="view">
            <h1>Gestion <span>Structure</span></h1>
            <div class="club-card" style="border-color: var(--padel-yellow);">
                <h3 style="margin-top:0">Ajouter un Club</h3>
                <div style="display:flex; gap:10px;">
                    <input type="text" id="new-club-name" placeholder="Nom du Club" style="flex:1; padding:12px; border-radius:8px; background:#000; color:#fff; border:1px solid #333;">
                    <button onclick="createClub()" class="primary-btn">CRÉER</button>
                </div>
            </div>
            <div id="club-mgmt-list"></div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getDatabase, ref, onValue, set, push, remove, update } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

        const fbConfig = { apiKey: "AIzaSyCjlHL7GEXFvnrNzZAIEZyl-WCqUI3txiM", authDomain: "scoretrak-123.firebaseapp.com", databaseURL: "https://scoretrak-123-default-rtdb.europe-west1.firebasedatabase.app", projectId: "scoretrak-123" };
        const app = initializeApp(fbConfig); const db = getDatabase(app);

        let globalData = {};
        const TV_BASE = "https://score-trak.vercel.app/PUB.html";

        window.login = () => {
            if(document.getElementById('adm-u').value === "master" && document.getElementById('adm-p').value === "score2026") {
                document.getElementById('login-overlay').style.display = 'none';
                sync();
            } else alert("Erreur identifiants");
        };

        window.showView = (v) => {
            document.querySelectorAll('.view').forEach(x => x.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(x => x.classList.remove('active'));
            document.getElementById('view-'+v).classList.add('active');
            document.getElementById('nav-'+v).classList.add('active');
        };

        function sync() {
            onValue(ref(db, 'clubs'), snap => {
                globalData = snap.val() || {};
                updateFilters();
                renderDashboard();
                renderManagement();
            });
        }

        function updateFilters() {
            const sel = document.getElementById('filter-club');
            const cur = sel.value;
            sel.innerHTML = '<option value="all">TOUS LES CLUBS</option>';
            Object.keys(globalData).forEach(id => { sel.innerHTML += `<option value="${id}">${globalData[id].name.toUpperCase()}</option>`; });
            sel.value = cur;
        }

        window.renderDashboard = () => {
            const list = document.getElementById('monitor-list');
            const clubFilter = document.getElementById('filter-club').value;
            const search = document.getElementById('search-court').value.toLowerCase();
            list.innerHTML = "";

            Object.keys(globalData).forEach(clubId => {
                if (clubFilter !== 'all' && clubFilter !== clubId) return;
                const club = globalData[clubId];
                if (!club.courts) return;

                Object.keys(club.courts).forEach(courtId => {
                    const c = club.courts[courtId];
                    if (search && !c.name.toLowerCase().includes(search)) return;

                    const isFini = c.winner != null;
                    const isLive = c.status === 'active';
                    const isSetup = c.status === 'setup';
                    
                    // Noms et Sets visibles seulement si actif/fini
                    const showNames = isLive || isFini;
                    
                    let setsA = [], setsB = [];
                    if(showNames) {
                        for(let i=1; i<=3; i++) {
                            if(c['s'+i+'A'] !== undefined) {
                                setsA.push(c['s'+i+'A']); setsB.push(c['s'+i+'B']);
                            }
                        }
                    }

                    // Badge Statut
                    let statusTxt = "VEILLE";
                    let badgeStyle = "";
                    if(isFini) { statusTxt = "TERMINÉ"; badgeStyle = "color:#ff4444; border-color:#ff4444"; }
                    else if(isLive) { statusTxt = "EN COURS"; badgeStyle = "color:var(--padel-yellow); border-color:var(--padel-yellow)"; }
                    else if(isSetup) { statusTxt = "CONFIGURATION EN COURS"; badgeStyle = "color:var(--padel-blue); border-color:var(--padel-blue)"; }

                    const labels = ["0", "15", "30", "40", "AD"];
                    const ptA = (c.gamesA === 6 && c.gamesB === 6) ? c.scoreA : (labels[c.scoreA] || "0");
                    const ptB = (c.gamesA === 6 && c.gamesB === 6) ? c.scoreB : (labels[c.scoreB] || "0");

                    const card = document.createElement('div');
                    card.className = `monitor-card ${isLive?'live':''} ${isSetup?'setup':''} ${isFini?'finished':''}`;
                    card.innerHTML = `
                        <div class="card-header">
                            <div>
                                <div class="club-tag">${club.name}</div>
                                <div style="font-weight:900; font-size:18px; margin-top:5px;">${c.name}</div>
                            </div>
                            <div class="status-label" style="${badgeStyle}">${statusTxt}</div>
                        </div>

                        <div class="score-container" style="opacity: ${showNames ? 1 : 0}">
                            <div class="team-row">
                                <div class="player-info">
                                    <div class="player-names">${c.pA1} / ${c.pA2}</div>
                                    <div class="set-history">${setsA.map(s => `<span class="set-pill">${s}</span>`).join('')}</div>
                                </div>
                                <div class="current-point">${isFini ? c.setsA : ptA}</div>
                            </div>
                            <div class="team-row">
                                <div class="player-info">
                                    <div class="player-names">${c.pB1} / ${c.pB2}</div>
                                    <div class="set-history">${setsB.map(s => `<span class="set-pill">${s}</span>`).join('')}</div>
                                </div>
                                <div class="current-point">${isFini ? c.setsB : ptB}</div>
                            </div>
                        </div>

                        <button class="btn-reset" onclick="resetCourt('${clubId}','${courtId}')">
                            ${isFini ? 'Nettoyer le terrain' : 'Forcer Reset'}
                        </button>
                    `;
                    list.appendChild(card);
                });
            });
        };

        function renderManagement() {
            const container = document.getElementById('club-mgmt-list');
            container.innerHTML = "";
            Object.keys(globalData).forEach(cid => {
                const club = globalData[cid];
                let courts = "";
                if(club.courts) {
                    Object.keys(club.courts).forEach(tid => {
                        const url = `${TV_BASE}?clubId=${cid}&courtId=${tid}`;
                        courts += `
                            <div class="court-row">
                                <span style="font-weight:bold">${club.courts[tid].name}</span>
                                <div>
                                    <button class="btn-copy" onclick="copy('${url}')">🔗 LIEN TV</button>
                                    <button onclick="deleteCourt('${cid}','${tid}')" style="background:none; color:#555; border:none; cursor:pointer; font-size:18px; margin-left:10px">×</button>
                                </div>
                            </div>`;
                    });
                }
                container.innerHTML += `
                    <div class="club-card">
                        <div style="display:flex; justify-content:space-between; margin-bottom:15px; border-bottom:1px solid #222; padding-bottom:10px">
                            <h2 style="margin:0; color:var(--padel-blue); font-family:Orbitron; font-size:18px;">${club.name}</h2>
                            <button onclick="deleteClub('${cid}')" style="background:none; border:none; color:#444; font-size:9px; cursor:pointer">SUPPRIMER CLUB</button>
                        </div>
                        ${courts}
                        <div style="display:flex; gap:10px; margin-top:15px">
                            <input type="text" id="in-${cid}" placeholder="Nouveau terrain..." style="flex:1; background:#000; border:1px solid #333; color:white; padding:10px; border-radius:8px;">
                            <button onclick="addCourt('${cid}')" class="primary-btn" style="padding:10px 20px">+</button>
                        </div>
                    </div>`;
            });
        }

        window.createClub = () => { const n = document.getElementById('new-club-name').value; if(n) { push(ref(db, 'clubs'), {name:n}); document.getElementById('new-club-name').value=""; } };
        window.addCourt = (cid) => {
            const n = document.getElementById('in-'+cid).value;
            if(n) push(ref(db, `clubs/${cid}/courts`), { 
                name:n, status:'idle', pA1:'?', pA2:'?', pB1:'?', pB2:'?', 
                scoreA:0, scoreB:0, gamesA:0, gamesB:0, setsA:0, setsB:0, serverTeam:'A' 
            });
        };
        window.resetCourt = (cid, tid) => { if(confirm("Voulez-vous réinitialiser ce terrain ?")) update(ref(db, `clubs/${cid}/courts/${tid}`), {status:'idle', winner:null, scoreA:0, scoreB:0, gamesA:0, gamesB:0, setsA:0, setsB:0, s1A:null, s1B:null, s2A:null, s2B:null, s3A:null, s3B:null}); };
        window.deleteCourt = (cid, tid) => { if(confirm("Supprimer ce terrain ?")) remove(ref(db, `clubs/${cid}/courts/${tid}`)); };
        window.deleteClub = (cid) => { if(confirm("Supprimer tout le club ?")) remove(ref(db, `clubs/${cid}`)); };
        window.copy = (t) => { navigator.clipboard.writeText(t); alert("Lien TV Copié !"); };
    </script>
</body>
</html>
